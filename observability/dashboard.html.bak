<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OpenClaw — Agent Monitor</title>
<style>
/* ─── Reset & Base ─── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #0a0a12;
  --bg-card: #12121e;
  --bg-card-hover: #1a1a2e;
  --bg-surface: #16162a;
  --border: #2a2a44;
  --border-light: #3a3a55;
  --text: #e2e8f0;
  --text-dim: #94a3b8;
  --text-muted: #64748b;
  --accent: #ef4444;
  --green: #22c55e;
  --blue: #3b82f6;
  --purple: #a855f7;
  --yellow: #f59e0b;
  --orange: #f97316;
  --cyan: #06b6d4;
  --pink: #ec4899;
  --red: #ef4444;
}

body {
  font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ─── Header ─── */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 24px;
  background: linear-gradient(180deg, #12121e 0%, var(--bg) 100%);
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.logo {
  font-size: 28px;
  line-height: 1;
}

.header h1 {
  font-size: 18px;
  font-weight: 600;
  letter-spacing: -0.02em;
}

.header h1 span {
  color: var(--text-dim);
  font-weight: 400;
  font-size: 14px;
  margin-left: 8px;
}

.status-badge {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 14px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 500;
}

.status-badge.live {
  background: rgba(34, 197, 94, 0.12);
  color: var(--green);
  border: 1px solid rgba(34, 197, 94, 0.25);
}

.status-badge.offline {
  background: rgba(239, 68, 68, 0.12);
  color: var(--red);
  border: 1px solid rgba(239, 68, 68, 0.25);
}

.pulse {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--green);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.3); }
}

/* ─── Layout ─── */
.main {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
  max-width: 1600px;
  margin: 0 auto;
  padding: 20px 24px;
}

/* ─── Topology Section ─── */
.topology {
  margin-bottom: 24px;
}

.section-title {
  font-size: 13px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-muted);
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.section-title::after {
  content: "";
  flex: 1;
  height: 1px;
  background: var(--border);
}

.agent-graph {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
  position: relative;
}

.agent-row {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
}

.connector-row {
  display: flex;
  justify-content: center;
  height: 40px;
  position: relative;
  width: 100%;
}

.connector-line {
  position: absolute;
  top: 0;
  width: 2px;
  height: 100%;
  background: var(--border);
}

.connector-horizontal {
  position: absolute;
  top: 50%;
  height: 2px;
  background: var(--border);
}

/* ─── Agent Card ─── */
.agent-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 16px 20px;
  min-width: 180px;
  cursor: pointer;
  transition: all 0.25s ease;
  position: relative;
  overflow: hidden;
}

.agent-card:hover {
  background: var(--bg-card-hover);
  border-color: var(--border-light);
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
}

.agent-card.selected {
  border-color: var(--accent);
  box-shadow: 0 0 0 1px var(--accent), 0 8px 25px rgba(239, 68, 68, 0.15);
}

.agent-card.working {
  animation: cardGlow 3s ease-in-out infinite;
}

@keyframes cardGlow {
  0%, 100% { box-shadow: 0 0 0 0 transparent; }
  50% { box-shadow: 0 0 20px -5px var(--agent-color, var(--green)); }
}

.agent-card-top {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 8px;
}

.agent-icon {
  font-size: 24px;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.05);
  border-radius: 10px;
}

.agent-info h3 {
  font-size: 15px;
  font-weight: 600;
  line-height: 1.2;
}

.agent-info .role {
  font-size: 12px;
  color: var(--text-muted);
}

.agent-status {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  margin-top: 6px;
}

.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.status-dot.idle { background: var(--text-muted); }
.status-dot.working { background: var(--green); animation: pulse 1.5s ease-in-out infinite; }
.status-dot.error { background: var(--red); }

.agent-task {
  font-size: 12px;
  color: var(--text-dim);
  margin-top: 8px;
  padding-top: 8px;
  border-top: 1px solid var(--border);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.agent-stats {
  display: flex;
  gap: 12px;
  margin-top: 8px;
  font-size: 11px;
  color: var(--text-muted);
}

.agent-stats .stat {
  display: flex;
  align-items: center;
  gap: 4px;
}

/* ─── Bottom Grid ─── */
.bottom-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

@media (max-width: 1000px) {
  .bottom-grid { grid-template-columns: 1fr; }
}

/* ─── Detail Panel ─── */
.detail-panel {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 20px;
  min-height: 300px;
}

.detail-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  min-height: 260px;
  color: var(--text-muted);
  font-size: 14px;
  gap: 8px;
}

.detail-empty .icon { font-size: 36px; opacity: 0.4; }

.detail-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--border);
}

.detail-header .agent-icon { font-size: 28px; }
.detail-header h2 { font-size: 18px; font-weight: 600; }
.detail-header .role-tag {
  background: rgba(255,255,255,0.08);
  padding: 3px 10px;
  border-radius: 6px;
  font-size: 12px;
  color: var(--text-dim);
}

.detail-section {
  margin-bottom: 16px;
}

.detail-section h4 {
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text-muted);
  margin-bottom: 8px;
}

.detail-section .content {
  font-size: 13px;
  line-height: 1.6;
  color: var(--text-dim);
  background: var(--bg-surface);
  padding: 12px;
  border-radius: 8px;
  max-height: 200px;
  overflow-y: auto;
  white-space: pre-wrap;
  word-break: break-word;
}

.run-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  max-height: 300px;
  overflow-y: auto;
}

.run-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 10px 12px;
  background: var(--bg-surface);
  border-radius: 8px;
  border-left: 3px solid var(--border);
  cursor: pointer;
  transition: background 0.2s;
}

.run-item:hover {
  background: var(--bg-card-hover);
}

.run-item.status-completed { border-left-color: var(--green); }
.run-item.status-error { border-left-color: var(--red); }
.run-item.status-running { border-left-color: var(--yellow); }

.run-item .run-task {
  font-size: 13px;
  color: var(--text);
  flex: 1;
  line-height: 1.4;
}

.run-item .run-meta {
  font-size: 11px;
  color: var(--text-muted);
  display: flex;
  gap: 8px;
  margin-top: 4px;
}

.run-item .run-time {
  font-size: 11px;
  color: var(--text-muted);
  white-space: nowrap;
}

.run-item .run-duration {
  font-size: 11px;
  color: var(--text-dim);
  white-space: nowrap;
  background: rgba(255,255,255,0.05);
  padding: 1px 6px;
  border-radius: 4px;
}

/* ─── Activity Feed ─── */
.activity-feed {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 20px;
  display: flex;
  flex-direction: column;
  min-height: 300px;
  max-height: 500px;
}

.feed-list {
  flex: 1;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding-right: 4px;
}

.feed-item {
  display: flex;
  gap: 10px;
  padding: 8px 10px;
  border-radius: 8px;
  font-size: 13px;
  line-height: 1.4;
  transition: background 0.15s;
  animation: feedIn 0.3s ease-out;
}

@keyframes feedIn {
  from { opacity: 0; transform: translateX(-10px); }
  to { opacity: 1; transform: translateX(0); }
}

.feed-item:hover {
  background: rgba(255,255,255,0.03);
}

.feed-time {
  color: var(--text-muted);
  font-size: 11px;
  font-family: 'Cascadia Code', 'Consolas', monospace;
  white-space: nowrap;
  min-width: 60px;
  padding-top: 1px;
}

.feed-icon {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  flex-shrink: 0;
}

.feed-icon.agent_active { background: rgba(34,197,94,0.15); color: var(--green); }
.feed-icon.agent_message { background: rgba(59,130,246,0.15); color: var(--blue); }
.feed-icon.task_result { background: rgba(168,85,247,0.15); color: var(--purple); }
.feed-icon.error { background: rgba(239,68,68,0.15); color: var(--red); }
.feed-icon.warning { background: rgba(245,158,11,0.15); color: var(--yellow); }
.feed-icon.ws_op { background: rgba(100,116,139,0.15); color: var(--text-muted); }

.feed-text {
  color: var(--text-dim);
  flex: 1;
  word-break: break-word;
}

.feed-text strong {
  color: var(--text);
  font-weight: 600;
}

/* ─── Scrollbar ─── */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--border-light); }

/* ─── Connections SVG ─── */
.connections-svg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
}

.conn-line {
  stroke: var(--border);
  stroke-width: 2;
  fill: none;
}

.conn-line.active {
  stroke: var(--green);
  stroke-width: 2;
  filter: drop-shadow(0 0 4px rgba(34,197,94,0.4));
  animation: lineFlow 1.5s linear infinite;
}

@keyframes lineFlow {
  from { stroke-dashoffset: 20; }
  to { stroke-dashoffset: 0; }
}

.conn-line.active {
  stroke-dasharray: 6 4;
}

/* ─── Stats Bar ─── */
.stats-bar {
  display: flex;
  gap: 20px;
  margin-bottom: 20px;
  flex-wrap: wrap;
}

.stat-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 12px 18px;
  min-width: 130px;
}

.stat-card .label {
  font-size: 11px;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.stat-card .value {
  font-size: 24px;
  font-weight: 700;
  margin-top: 2px;
}

.stat-card .value.green { color: var(--green); }
.stat-card .value.red { color: var(--red); }
.stat-card .value.blue { color: var(--blue); }
.stat-card .value.yellow { color: var(--yellow); }

/* ─── Run Detail Modal ─── */
.modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  z-index: 200;
  backdrop-filter: blur(4px);
  justify-content: center;
  align-items: center;
}

.modal-overlay.visible {
  display: flex;
}

.modal {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 24px;
  max-width: 700px;
  width: 90%;
  max-height: 80vh;
  overflow-y: auto;
}

.modal h2 {
  font-size: 18px;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.modal .close-btn {
  margin-left: auto;
  background: none;
  border: none;
  color: var(--text-muted);
  font-size: 20px;
  cursor: pointer;
  padding: 4px 10px;
  border-radius: 6px;
}

.modal .close-btn:hover {
  background: rgba(255,255,255,0.08);
  color: var(--text);
}

.kv-grid {
  display: grid;
  grid-template-columns: 140px 1fr;
  gap: 8px 12px;
  font-size: 13px;
}

.kv-grid .label {
  color: var(--text-muted);
  font-weight: 500;
}

.kv-grid .val {
  color: var(--text);
  word-break: break-word;
}

.badge {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 12px;
  font-weight: 600;
}

.badge.ok { background: rgba(34,197,94,0.15); color: var(--green); }
.badge.err { background: rgba(239,68,68,0.15); color: var(--red); }
.badge.run { background: rgba(245,158,11,0.15); color: var(--yellow); }
</style>
</head>
<body>

<!-- ─── Header ─── -->
<header class="header">
  <div class="header-left">
    <div class="logo">🦞</div>
    <h1>OpenClaw<span>Agent Monitor</span></h1>
  </div>
  <div class="status-badge live" id="connectionStatus">
    <div class="pulse" id="pulseIndicator"></div>
    <span id="statusText">Connecting...</span>
  </div>
</header>

<!-- ─── Main ─── -->
<main class="main">

  <!-- Stats -->
  <div class="stats-bar" id="statsBar">
    <div class="stat-card"><div class="label">Total Runs</div><div class="value blue" id="statTotalRuns">-</div></div>
    <div class="stat-card"><div class="label">Active</div><div class="value green" id="statActive">0</div></div>
    <div class="stat-card"><div class="label">Errors</div><div class="value red" id="statErrors">0</div></div>
    <div class="stat-card"><div class="label">Agents Online</div><div class="value yellow" id="statOnline">-</div></div>
  </div>

  <!-- Agent Topology -->
  <section class="topology">
    <div class="section-title">Agent Topology</div>
    <div class="agent-graph" id="agentGraph">
      <!-- Filled by JS -->
    </div>
  </section>

  <!-- Bottom: Detail + Feed -->
  <div class="bottom-grid">
    <!-- Detail Panel -->
    <div class="detail-panel" id="detailPanel">
      <div class="section-title">Agent Details</div>
      <div class="detail-empty" id="detailEmpty">
        <div class="icon">👆</div>
        <div>Click an agent to see details</div>
      </div>
      <div id="detailContent" style="display:none"></div>
    </div>

    <!-- Activity Feed -->
    <div class="activity-feed">
      <div class="section-title">Live Activity</div>
      <div class="feed-list" id="feedList">
        <div class="feed-item">
          <div class="feed-time">--:--</div>
          <div class="feed-icon ws_op">⏳</div>
          <div class="feed-text">Waiting for events...</div>
        </div>
      </div>
    </div>
  </div>

</main>

<!-- Run Detail Modal -->
<div class="modal-overlay" id="modalOverlay" onclick="if(event.target===this)closeModal()">
  <div class="modal" id="modalContent"></div>
</div>

<script>
// ─── State ───
let state = { agents: {}, runs: [], events: [], meta: {} };
let selectedAgent = null;

const AGENT_META = {
  main:      { name: "Main (CTO)",   icon: "🦞", color: "#ef4444", role: "Orchestrator" },
  architect: { name: "Strut",        icon: "🏗️", color: "#3b82f6", role: "Architect" },
  coder:     { name: "Hex",          icon: "💻", color: "#22c55e", role: "Coder" },
  reviewer:  { name: "Lens",         icon: "🔍", color: "#a855f7", role: "Reviewer" },
  planner:   { name: "Atlas",        icon: "🗺️", color: "#f59e0b", role: "Planner" },
  senior:    { name: "Forge",        icon: "⚒️", color: "#ec4899", role: "Senior Dev" },
  data:      { name: "Qubit",        icon: "🗄️", color: "#06b6d4", role: "Data Engineer" },
  designer:  { name: "Iris",         icon: "🎨", color: "#f97316", role: "Designer" },
  security:  { name: "Vault",        icon: "🛡️", color: "#64748b", role: "Security" },
  finance:   { name: "Quant",        icon: "📈", color: "#14b8a6", role: "Finance" },
};

// ─── Time format ───
function fmtTime(ts) {
  if (!ts) return "--:--";
  if (typeof ts === "string") {
    const m = ts.match(/(\d{2}:\d{2}:\d{2})/);
    return m ? m[1].slice(0,5) : ts.slice(11,16);
  }
  const d = new Date(ts);
  return d.toLocaleTimeString("fr-FR", { hour: "2-digit", minute: "2-digit" });
}

function fmtDuration(ms) {
  if (!ms) return "-";
  if (ms < 1000) return ms + "ms";
  if (ms < 60000) return (ms / 1000).toFixed(1) + "s";
  return (ms / 60000).toFixed(1) + "min";
}

function fmtDate(ts) {
  if (!ts) return "-";
  return new Date(ts).toLocaleString("fr-FR", { hour: "2-digit", minute: "2-digit", second: "2-digit" });
}

function escHtml(s) {
  const d = document.createElement("div"); d.textContent = s; return d.innerHTML;
}

// ─── Render Agent Graph ───
function renderGraph() {
  const graph = document.getElementById("agentGraph");
  const agents = state.agents;

  // Main agent on top
  const mainAgent = agents.main || { ...AGENT_META.main, id: "main", status: "idle", runCount: 0, errorCount: 0 };
  
  // Sub-agents = all others that have activity or are configured
  const subIds = ["architect", "coder", "reviewer", "planner", "senior", "data", "designer", "security", "finance"];
  const activeSubs = subIds.filter(id => agents[id]?.runCount > 0 || agents[id]?.status === "working");
  const configuredSubs = ["architect", "coder", "reviewer"]; // core team
  const shownSubs = [...new Set([...configuredSubs, ...activeSubs])];

  let html = '';

  // Main agent card
  html += '<div class="agent-row">';
  html += renderAgentCard(mainAgent);
  html += '</div>';

  // Connection lines
  html += '<div class="connector-row"><svg style="width:100%;height:100%">';
  html += '<line x1="50%" y1="0" x2="50%" y2="100%" stroke="var(--border)" stroke-width="2" />';
  html += '</svg></div>';

  // Sub-agent cards
  html += '<div class="agent-row">';
  for (const id of shownSubs) {
    const a = agents[id] || { ...AGENT_META[id], id, status: "idle", runCount: 0, errorCount: 0 };
    html += renderAgentCard(a);
  }
  html += '</div>';

  graph.innerHTML = html;

  // Attach click handlers
  graph.querySelectorAll(".agent-card").forEach(card => {
    card.addEventListener("click", () => selectAgent(card.dataset.agent));
  });
}

function renderAgentCard(agent) {
  const meta = AGENT_META[agent.id] || agent;
  const sel = selectedAgent === agent.id ? "selected" : "";
  const work = agent.status === "working" ? "working" : "";
  const statusLabel = agent.status === "working" ? "Working" : agent.status === "error" ? "Error" : "Idle";

  return `
    <div class="agent-card ${sel} ${work}" data-agent="${agent.id}" style="--agent-color:${meta.color}">
      <div class="agent-card-top">
        <div class="agent-icon">${meta.icon}</div>
        <div class="agent-info">
          <h3>${escHtml(meta.name)}</h3>
          <div class="role">${escHtml(meta.role)}</div>
        </div>
      </div>
      <div class="agent-status">
        <div class="status-dot ${agent.status}"></div>
        <span>${statusLabel}</span>
      </div>
      ${agent.currentTask ? `<div class="agent-task">${escHtml(agent.currentTask)}</div>` : ""}
      <div class="agent-stats">
        <div class="stat">📋 ${agent.runCount || 0} runs</div>
        ${agent.errorCount ? `<div class="stat" style="color:var(--red)">⚠ ${agent.errorCount} errors</div>` : ""}
      </div>
    </div>
  `;
}

// ─── Select Agent → Show Details ───
function selectAgent(agentId) {
  selectedAgent = selectedAgent === agentId ? null : agentId;
  renderGraph();
  renderDetail();
}

function renderDetail() {
  const empty = document.getElementById("detailEmpty");
  const content = document.getElementById("detailContent");

  if (!selectedAgent) {
    empty.style.display = "flex";
    content.style.display = "none";
    return;
  }

  empty.style.display = "none";
  content.style.display = "block";

  const meta = AGENT_META[selectedAgent] || {};
  const agentRuns = state.runs.filter(r => r.agent === selectedAgent).slice(0, 20);

  let html = `
    <div class="detail-header">
      <div class="agent-icon" style="font-size:32px">${meta.icon || "🤖"}</div>
      <div>
        <h2>${escHtml(meta.name || selectedAgent)}</h2>
        <span class="role-tag">${escHtml(meta.role || "Agent")}</span>
      </div>
    </div>
  `;

  if (agentRuns.length === 0) {
    html += `<div class="detail-section"><div class="content">No runs recorded for this agent yet.</div></div>`;
  } else {
    html += `<div class="detail-section"><h4>Recent Runs (${agentRuns.length})</h4><div class="run-list">`;
    for (const run of agentRuns) {
      const statusClass = run.error ? "status-error" : run.endedAt ? "status-completed" : "status-running";
      const statusBadge = run.error ? "⛔" : run.endedAt ? "✅" : "⏳";
      html += `
        <div class="run-item ${statusClass}" onclick="showRunDetail('${run.id}')">
          <div style="font-size:16px">${statusBadge}</div>
          <div style="flex:1">
            <div class="run-task">${escHtml(run.task || "No task description")}</div>
            <div class="run-meta">
              <span>${fmtDate(run.createdAt)}</span>
              ${run.error ? `<span style="color:var(--red)">${escHtml(run.error.slice(0, 80))}</span>` : ""}
            </div>
          </div>
          <div class="run-duration">${fmtDuration(run.durationMs)}</div>
        </div>
      `;
    }
    html += `</div></div>`;
  }

  content.innerHTML = html;
}

// ─── Run Detail Modal ───
function showRunDetail(runId) {
  const run = state.runs.find(r => r.id === runId);
  if (!run) return;

  const meta = AGENT_META[run.agent] || {};
  const statusBadge = run.error ? '<span class="badge err">Error</span>' :
                      run.endedAt ? '<span class="badge ok">Completed</span>' :
                      '<span class="badge run">Running</span>';

  document.getElementById("modalContent").innerHTML = `
    <h2>
      <span>${meta.icon || "🤖"}</span>
      <span>${escHtml(meta.name || run.agent)}</span>
      ${statusBadge}
      <button class="close-btn" onclick="closeModal()">✕</button>
    </h2>
    <div class="kv-grid">
      <div class="label">Run ID</div><div class="val" style="font-family:monospace;font-size:12px">${run.id}</div>
      <div class="label">Agent</div><div class="val">${escHtml(run.agent)} (${escHtml(meta.role || "")})</div>
      <div class="label">Parent</div><div class="val">${escHtml(run.parent || "-")}</div>
      <div class="label">Status</div><div class="val">${run.error ? "Error" : run.endedAt ? "Completed" : "Running"}</div>
      <div class="label">Created</div><div class="val">${fmtDate(run.createdAt)}</div>
      <div class="label">Started</div><div class="val">${fmtDate(run.startedAt)}</div>
      <div class="label">Ended</div><div class="val">${run.endedAt ? fmtDate(run.endedAt) : "Still running..."}</div>
      <div class="label">Duration</div><div class="val">${fmtDuration(run.durationMs)}</div>
      <div class="label">End Reason</div><div class="val">${escHtml(run.endedReason || "-")}</div>
    </div>
    <div class="detail-section" style="margin-top:16px">
      <h4>Task / Prompt</h4>
      <div class="content">${escHtml(run.task || "No task description")}</div>
    </div>
    ${run.error ? `<div class="detail-section"><h4>Error</h4><div class="content" style="color:var(--red)">${escHtml(run.error)}</div></div>` : ""}
  `;

  document.getElementById("modalOverlay").classList.add("visible");
}

function closeModal() {
  document.getElementById("modalOverlay").classList.remove("visible");
}

document.addEventListener("keydown", e => { if (e.key === "Escape") closeModal(); });

// ─── Feed ───
function renderFeed() {
  const list = document.getElementById("feedList");
  const events = state.events.slice(-60).reverse();

  if (events.length === 0) return;

  list.innerHTML = events.map(evt => {
    const icon = {
      agent_active: "🟢", agent_message: "💬", task_result: "📋",
      error: "🔴", warning: "⚠️", ws_op: "⚡"
    }[evt.type] || "•";

    let text = "";
    switch (evt.type) {
      case "agent_active":
        text = `<strong>${escHtml(evt.agent)}</strong> became active`;
        break;
      case "agent_message":
        text = escHtml(evt.message);
        break;
      case "task_result":
        text = `<strong>Result:</strong> ${escHtml(evt.message.slice(0, 200))}`;
        break;
      case "error":
        text = `<strong style="color:var(--red)">Error:</strong> ${escHtml(evt.message)}`;
        break;
      case "warning":
        text = `<strong style="color:var(--yellow)">Warning:</strong> ${escHtml(evt.message)}`;
        break;
      case "ws_op":
        text = `<strong>${escHtml(evt.operation)}</strong> ${evt.durationMs}ms`;
        break;
      default:
        text = escHtml(JSON.stringify(evt));
    }

    return `
      <div class="feed-item">
        <div class="feed-time">${fmtTime(evt.time)}</div>
        <div class="feed-icon ${evt.type}">${icon}</div>
        <div class="feed-text">${text}</div>
      </div>
    `;
  }).join("");
}

// ─── Stats ───
function renderStats() {
  const runs = state.runs;
  const agents = state.agents;
  const activeCount = Object.values(agents).filter(a => a.status === "working").length;
  const errorCount = runs.filter(r => r.error).length;
  const onlineCount = Object.values(agents).filter(a => a.runCount > 0 || a.status === "working").length;

  document.getElementById("statTotalRuns").textContent = runs.length;
  document.getElementById("statActive").textContent = activeCount;
  document.getElementById("statErrors").textContent = errorCount;
  document.getElementById("statOnline").textContent = onlineCount;
}

// ─── Data Loading ───
async function loadInitialState() {
  try {
    const res = await fetch("/api/state");
    const data = await res.json();
    state = data;
    renderAll();
    setConnected(true);
  } catch (err) {
    console.error("Failed to load state", err);
    setConnected(false);
  }
}

function renderAll() {
  renderGraph();
  renderDetail();
  renderFeed();
  renderStats();
}

function setConnected(connected) {
  const badge = document.getElementById("connectionStatus");
  const pulse = document.getElementById("pulseIndicator");
  const text = document.getElementById("statusText");

  if (connected) {
    badge.className = "status-badge live";
    pulse.style.background = "var(--green)";
    text.textContent = "LIVE";
  } else {
    badge.className = "status-badge offline";
    pulse.style.background = "var(--red)";
    pulse.style.animation = "none";
    text.textContent = "Offline";
  }
}

// ─── SSE Connection ───
function connectSSE() {
  const evtSource = new EventSource("/events");

  evtSource.addEventListener("connected", () => {
    setConnected(true);
  });

  evtSource.addEventListener("log", (e) => {
    try {
      const evt = JSON.parse(e.data);
      state.events.push(evt);
      if (state.events.length > 200) state.events.shift();
      renderFeed();
    } catch {}
  });

  evtSource.addEventListener("runs", (e) => {
    try {
      const data = JSON.parse(e.data);
      state.runs = data.runs;
      state.agents = data.agents;
      renderGraph();
      renderDetail();
      renderStats();
    } catch {}
  });

  evtSource.onerror = () => {
    setConnected(false);
    evtSource.close();
    // Reconnect after 3s
    setTimeout(connectSSE, 3000);
  };
}

// ─── Init ───
loadInitialState();
connectSSE();

// Refresh full state every 30s as backup
setInterval(loadInitialState, 30000);
</script>
</body>
</html>
